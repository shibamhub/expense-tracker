<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Personal Expense Tracker</title>

  <!-- ============================================================
       FONTS & ICONS
       - Google Fonts: 'Poppins' for a modern clean look
       - Tabler Icons: free icon library
  ============================================================ -->
  <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet"/>
  <link href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/tabler-icons.min.css" rel="stylesheet"/>

  <style>
    /* ============================================================
       CSS VARIABLES — change these to retheme the whole app!
       TRY: change --accent to #6C63FF for purple, #E94560 for red
    ============================================================ */
    :root {
      --accent:        #1D9E75;   /* main green accent color */
      --accent-light:  #E1F5EE;   /* light tint of accent */
      --bg:            #F4F6FB;   /* page background */
      --card-bg:       #FFFFFF;   /* card background */
      --text:          #1A1A2E;   /* primary text */
      --text-muted:    #6B7280;   /* muted/secondary text */
      --border:        #E5E7EB;   /* border color */
      --danger:        #E24B4A;   /* red for alerts */
      --danger-light:  #FCEBEB;
      --warning:       #EF9F27;   /* amber for warnings */
      --warning-light: #FAEEDA;
      --radius:        12px;      /* border radius */
      --shadow:        0 2px 12px rgba(0,0,0,0.07);
    }

    /* ============================================================
       RESET & BASE
    ============================================================ */
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Poppins', sans-serif;
      background: var(--bg);
      color: var(--text);
      min-height: 100vh;
      padding: 2rem 1rem;
    }

    /* ============================================================
       LAYOUT
    ============================================================ */
    .wrapper {
      max-width: 900px;
      margin: 0 auto;
    }

    /* App header */
    .app-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 2rem;
    }
    .app-header .logo {
      width: 42px; height: 42px;
      background: var(--accent);
      border-radius: 10px;
      display: flex; align-items: center; justify-content: center;
      color: white; font-size: 20px;
    }
    .app-header h1 {
      font-size: 22px;
      font-weight: 600;
      color: var(--text);
    }
    .app-header p {
      font-size: 13px;
      color: var(--text-muted);
    }

    /* Card */
    .card {
      background: var(--card-bg);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      padding: 1.25rem 1.5rem;
      box-shadow: var(--shadow);
      margin-bottom: 1.25rem;
    }
    .card-title {
      font-size: 14px;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 1rem;
      display: flex;
      align-items: center;
      gap: 8px;
    }
    .card-title i { color: var(--accent); font-size: 18px; }

    /* ============================================================
       SUMMARY METRICS
    ============================================================ */
    .summary-grid {
      display: grid;
      grid-template-columns: repeat(3, 1fr);
      gap: 1rem;
      margin-bottom: 1.25rem;
    }
    .metric-card {
      background: var(--card-bg);
      border-radius: var(--radius);
      border: 1px solid var(--border);
      padding: 1.25rem;
      box-shadow: var(--shadow);
    }
    .metric-icon {
      width: 36px; height: 36px;
      border-radius: 8px;
      background: var(--accent-light);
      display: flex; align-items: center; justify-content: center;
      color: var(--accent);
      font-size: 18px;
      margin-bottom: 12px;
    }
    .metric-label {
      font-size: 12px;
      color: var(--text-muted);
      margin-bottom: 4px;
    }
    .metric-value {
      font-size: 22px;
      font-weight: 600;
      color: var(--text);
    }
    .metric-value.danger { color: var(--danger); }
    .metric-value.success { color: var(--accent); }

    /* ============================================================
       ALERTS
    ============================================================ */
    .alert {
      display: flex; align-items: center; gap: 10px;
      padding: 12px 16px;
      border-radius: var(--radius);
      font-size: 13px;
      margin-bottom: 1rem;
      font-weight: 500;
    }
    .alert.danger  { background: var(--danger-light);  color: var(--danger);  border: 1px solid #F7C1C1; }
    .alert.warning { background: var(--warning-light); color: #854F0B; border: 1px solid #FAC775; }

    /* ============================================================
       FORM INPUTS
    ============================================================ */
    .form-grid {
      display: grid;
      grid-template-columns: 2fr 1fr 1fr 1fr;
      gap: 10px;
      align-items: end;
    }
    .field label {
      display: block;
      font-size: 12px;
      color: var(--text-muted);
      margin-bottom: 5px;
      font-weight: 500;
    }
    .field input,
    .field select {
      width: 100%;
      height: 40px;
      padding: 0 12px;
      border: 1px solid var(--border);
      border-radius: 8px;
      font-size: 13px;
      font-family: 'Poppins', sans-serif;
      color: var(--text);
      background: var(--bg);
      outline: none;
      transition: border 0.2s;
    }
    .field input:focus,
    .field select:focus {
      border-color: var(--accent);
      background: white;
    }
    .form-actions {
      display: flex;
      gap: 8px;
      margin-top: 1rem;
      justify-content: flex-end;
    }

    /* Budget row */
    .budget-row {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 10px;
      align-items: end;
    }

    /* ============================================================
       BUTTONS
    ============================================================ */
    .btn {
      height: 40px;
      padding: 0 18px;
      border-radius: 8px;
      font-size: 13px;
      font-family: 'Poppins', sans-serif;
      font-weight: 500;
      cursor: pointer;
      display: inline-flex;
      align-items: center;
      gap: 7px;
      border: 1px solid var(--border);
      background: white;
      color: var(--text);
      transition: all 0.15s;
    }
    .btn:hover { background: var(--bg); }
    .btn-primary {
      background: var(--accent);
      color: white;
      border-color: var(--accent);
    }
    .btn-primary:hover { opacity: 0.9; background: var(--accent); }
    .btn-save {
      background: var(--accent-light);
      color: var(--accent);
      border-color: var(--accent);
    }
    .btn-danger {
      color: var(--danger);
      border-color: #F7C1C1;
    }
    .btn-danger:hover { background: var(--danger-light); }

    /* Icon-only buttons */
    .icon-btn {
      width: 32px; height: 32px;
      border-radius: 7px;
      border: none;
      background: none;
      cursor: pointer;
      display: inline-flex; align-items: center; justify-content: center;
      font-size: 16px;
      color: var(--text-muted);
      transition: all 0.15s;
      flex-shrink: 0;
    }
    .icon-btn.edit:hover  { background: #E6F1FB; color: #185FA5; }
    .icon-btn.del:hover   { background: var(--danger-light); color: var(--danger); }

    /* ============================================================
       PROGRESS BAR
    ============================================================ */
    .progress-wrap {
      margin-top: 12px;
    }
    .progress-meta {
      display: flex;
      justify-content: space-between;
      font-size: 12px;
      color: var(--text-muted);
      margin-bottom: 6px;
    }
    .progress-bg {
      height: 8px;
      background: var(--bg);
      border-radius: 99px;
      overflow: hidden;
      border: 1px solid var(--border);
    }
    .progress-fill {
      height: 100%;
      border-radius: 99px;
      transition: width 0.5s ease;
      background: var(--accent);
    }

    /* ============================================================
       EXPENSE LIST
    ============================================================ */
    .two-col {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.25rem;
    }

    .expense-list { display: flex; flex-direction: column; gap: 6px; }

    /* Date group header */
    .date-group-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      padding: 6px 0 4px;
      border-bottom: 1px solid var(--border);
      margin-top: 8px;
    }
    .date-group-header:first-child { margin-top: 0; }
    .date-label {
      font-size: 12px;
      font-weight: 600;
      color: var(--text-muted);
      display: flex;
      align-items: center;
      gap: 5px;
    }
    .date-total {
      font-size: 12px;
      font-weight: 600;
      color: var(--accent);
    }

    /* Single expense row */
    .expense-item {
      display: flex;
      align-items: center;
      gap: 10px;
      padding: 10px 12px;
      background: var(--bg);
      border-radius: 9px;
      border: 1px solid transparent;
      transition: border 0.15s;
    }
    .expense-item:hover { border-color: var(--border); }

    /* Category badge */
    .badge {
      font-size: 10px;
      font-weight: 600;
      padding: 3px 9px;
      border-radius: 99px;
      text-transform: uppercase;
      letter-spacing: 0.4px;
      flex-shrink: 0;
    }
    .badge-food   { background: #FAEEDA; color: #854F0B; }
    .badge-travel { background: #E6F1FB; color: #185FA5; }
    .badge-study  { background: #EAF3DE; color: #3B6D11; }
    .badge-health { background: #FCEBEB; color: #A32D2D; }
    .badge-other  { background: #EEEDFE; color: #534AB7; }

    .expense-name   { flex: 1; font-size: 13px; color: var(--text); }
    .expense-amount { font-size: 13px; font-weight: 600; color: var(--text); min-width: 65px; text-align: right; }

    /* Edit form inline */
    .edit-form {
      background: #F0F9FF;
      border: 1px solid #378ADD;
      border-radius: 9px;
      padding: 12px;
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .edit-grid {
      display: grid;
      grid-template-columns: 1fr 1fr 1fr 1fr;
      gap: 8px;
    }
    .edit-grid .field input,
    .edit-grid .field select {
      height: 34px;
      font-size: 12px;
    }
    .edit-actions {
      display: flex;
      justify-content: flex-end;
      gap: 8px;
    }

    /* ============================================================
       CATEGORY BREAKDOWN
    ============================================================ */
    .cat-breakdown { display: flex; flex-direction: column; gap: 12px; }
    .cat-row { display: flex; align-items: center; gap: 10px; }
    .cat-dot {
      width: 10px; height: 10px;
      border-radius: 50%;
      flex-shrink: 0;
    }
    .cat-name { font-size: 13px; color: var(--text-muted); width: 60px; }
    .cat-bar-bg {
      flex: 1;
      height: 7px;
      background: var(--bg);
      border-radius: 99px;
      overflow: hidden;
      border: 1px solid var(--border);
    }
    .cat-bar-fill { height: 100%; border-radius: 99px; transition: width 0.4s; }
    .cat-pct  { font-size: 12px; color: var(--text-muted); width: 35px; text-align: right; }
    .cat-amt  { font-size: 13px; font-weight: 600; color: var(--text); width: 75px; text-align: right; }

    /* Empty state */
    .empty {
      text-align: center;
      padding: 2rem 0;
      color: var(--text-muted);
      font-size: 13px;
    }
    .empty i { font-size: 32px; display: block; margin-bottom: 8px; opacity: 0.4; }

    /* ============================================================
       RESPONSIVE — stacks on mobile
    ============================================================ */
    @media (max-width: 640px) {
      .summary-grid { grid-template-columns: 1fr 1fr; }
      .form-grid    { grid-template-columns: 1fr 1fr; }
      .two-col      { grid-template-columns: 1fr; }
      .edit-grid    { grid-template-columns: 1fr 1fr; }
    }
  </style>
</head>
<body>
<div class="wrapper">

  <!-- ── APP HEADER ── -->
  <div class="app-header">
    <div class="logo"><i class="ti ti-wallet"></i></div>
    <div>
      <h1>Expense Tracker</h1>
      <p>Track your spending, stay within budget</p>
    </div>
  </div>

  <!-- ── SUMMARY CARDS ── -->
  <div class="summary-grid">
    <div class="metric-card">
      <div class="metric-icon"><i class="ti ti-credit-card"></i></div>
      <div class="metric-label">Total spent</div>
      <div class="metric-value" id="total-spent">₹0</div>
    </div>
    <div class="metric-card">
      <div class="metric-icon"><i class="ti ti-target"></i></div>
      <div class="metric-label">Monthly budget</div>
      <div class="metric-value" id="budget-display">₹0</div>
    </div>
    <div class="metric-card">
      <div class="metric-icon"><i class="ti ti-pig-money"></i></div>
      <div class="metric-label">Remaining</div>
      <div class="metric-value" id="remaining">—</div>
    </div>
  </div>

  <!-- ── ALERT AREA ── -->
  <div id="alert-area"></div>

  <!-- ── BUDGET SETTER ── -->
  <div class="card">
    <div class="card-title"><i class="ti ti-target"></i> Set monthly budget</div>
    <div class="budget-row">
      <div class="field">
        <label>Budget amount (₹)</label>
        <input type="number" id="budget-input" placeholder="e.g. 5000" min="0"/>
      </div>
      <button class="btn btn-primary" onclick="setBudget()">
        <i class="ti ti-check"></i> Set budget
      </button>
    </div>
    <div id="budget-bar-wrap" style="display:none;">
      <div class="progress-wrap">
        <div class="progress-meta">
          <span>₹<span id="bar-spent">0</span> spent</span>
          <span id="bar-pct">0%</span>
        </div>
        <div class="progress-bg">
          <div class="progress-fill" id="budget-bar" style="width:0%;"></div>
        </div>
      </div>
    </div>
  </div>

  <!-- ── ADD EXPENSE ── -->
  <div class="card">
    <div class="card-title"><i class="ti ti-plus"></i> Add expense</div>
    <div class="form-grid">
      <div class="field">
        <label>Description</label>
        <input type="text" id="exp-name" placeholder="e.g. Lunch at canteen"/>
      </div>
      <div class="field">
        <label>Amount (₹)</label>
        <input type="number" id="exp-amount" placeholder="e.g. 120" min="0"/>
      </div>
      <div class="field">
        <label>Category</label>
        <select id="exp-cat">
          <option value="food">🍛 Food</option>
          <option value="travel">🚌 Travel</option>
          <option value="study">📚 Study</option>
          <option value="health">💊 Health</option>
          <option value="other">📦 Other</option>
        </select>
      </div>
      <div class="field">
        <label>Date</label>
        <input type="date" id="exp-date"/>
      </div>
    </div>
    <div class="form-actions">
      <button class="btn btn-primary" onclick="addExpense()">
        <i class="ti ti-plus"></i> Add expense
      </button>
    </div>
  </div>

  <!-- ── EXPENSES LIST + BREAKDOWN ── -->
  <div class="two-col">

    <div class="card">
      <div class="card-title"><i class="ti ti-list"></i> Expenses by date</div>
      <div class="expense-list" id="expense-list">
        <div class="empty"><i class="ti ti-receipt-off"></i>No expenses yet.<br>Add your first one above!</div>
      </div>
    </div>

    <div class="card">
      <div class="card-title"><i class="ti ti-chart-bar"></i> Category breakdown</div>
      <div class="cat-breakdown" id="cat-breakdown">
        <div class="empty"><i class="ti ti-chart-pie"></i>No data yet.</div>
      </div>
    </div>

  </div>

</div><!-- /wrapper -->

<!-- ============================================================
     JAVASCRIPT — all the logic lives here
     Read through each function to understand how it works!
============================================================ -->
<script>
  // ── DATA ──────────────────────────────────────────────────────
  let expenses  = [];   // array of expense objects
  let budget    = 0;    // monthly budget number
  let editingId = null; // id of expense being edited (null = none)

  const CATEGORIES = ['food', 'travel', 'study', 'health', 'other'];
  const CAT_COLORS = {
    food:   '#EF9F27',
    travel: '#378ADD',
    study:  '#639922',
    health: '#E24B4A',
    other:  '#7F77DD'
  };

  // Set today's date as default in the date input
  document.getElementById('exp-date').value = new Date().toISOString().split('T')[0];


  // ── SET BUDGET ───────────────────────────────────────────────
  function setBudget() {
    const val = parseFloat(document.getElementById('budget-input').value);
    if (!val || val <= 0) return alert('Please enter a valid budget amount!');
    budget = val;
    document.getElementById('budget-input').value = '';
    updateUI();
  }


  // ── ADD EXPENSE ──────────────────────────────────────────────
  function addExpense() {
    const name   = document.getElementById('exp-name').value.trim();
    const amount = parseFloat(document.getElementById('exp-amount').value);
    const cat    = document.getElementById('exp-cat').value;
    const date   = document.getElementById('exp-date').value;

    // Validation — check all fields are filled
    if (!name)           return alert('Please enter a description!');
    if (!amount || amount <= 0) return alert('Please enter a valid amount!');
    if (!date)           return alert('Please select a date!');

    // Create a new expense object and push to array
    expenses.push({
      id: Date.now(),   // unique id using timestamp
      name,
      amount,
      cat,
      date
    });

    // Clear the form
    document.getElementById('exp-name').value   = '';
    document.getElementById('exp-amount').value = '';
    document.getElementById('exp-date').value   = new Date().toISOString().split('T')[0];

    updateUI(); // re-render everything
  }


  // ── DELETE EXPENSE ───────────────────────────────────────────
  function deleteExpense(id) {
    if (!confirm('Delete this expense?')) return;
    expenses = expenses.filter(e => e.id !== id);
    if (editingId === id) editingId = null;
    updateUI();
  }


  // ── START EDITING ────────────────────────────────────────────
  function startEdit(id) {
    editingId = id;
    updateUI();
  }

  function cancelEdit() {
    editingId = null;
    updateUI();
  }

  // ── SAVE EDITED EXPENSE ──────────────────────────────────────
  function saveEdit(id) {
    const name   = document.getElementById('edit-name-'   + id).value.trim();
    const amount = parseFloat(document.getElementById('edit-amount-' + id).value);
    const cat    = document.getElementById('edit-cat-'    + id).value;
    const date   = document.getElementById('edit-date-'   + id).value;

    if (!name || !amount || amount <= 0 || !date) return alert('Please fill all fields!');

    // Update the matching expense in the array
    expenses = expenses.map(e =>
      e.id === id ? { ...e, name, amount, cat, date } : e
    );

    editingId = null;
    updateUI();
  }


  // ── FORMAT DATE for display ──────────────────────────────────
  function formatDate(dateStr) {
    const d = new Date(dateStr + 'T00:00:00');
    return d.toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' });
  }


  // ── MAIN UI UPDATE ────────────────────────────────────────────
  // This runs every time data changes — re-renders the full UI
  function updateUI() {

    // 1. Calculate totals
    const total     = expenses.reduce((sum, e) => sum + e.amount, 0);
    const remaining = budget - total;

    // 2. Update summary cards
    document.getElementById('total-spent').textContent   = '₹' + total.toLocaleString('en-IN');
    document.getElementById('budget-display').textContent = budget > 0 ? '₹' + budget.toLocaleString('en-IN') : '₹0';

    const remEl = document.getElementById('remaining');
    if (budget > 0) {
      remEl.textContent = remaining < 0
        ? '₹' + Math.abs(remaining).toLocaleString('en-IN') + ' over'
        : '₹' + remaining.toLocaleString('en-IN');
      remEl.className = 'metric-value ' + (remaining < 0 ? 'danger' : 'success');
    } else {
      remEl.textContent = '—';
      remEl.className = 'metric-value';
    }

    // 3. Budget alert
    const alertArea = document.getElementById('alert-area');
    if (budget > 0 && total >= budget) {
      alertArea.innerHTML = `<div class="alert danger">
        <i class="ti ti-alert-triangle"></i>
        Budget exceeded! You spent ₹${(total - budget).toLocaleString('en-IN')} over your limit.
      </div>`;
    } else if (budget > 0 && total >= budget * 0.8) {
      alertArea.innerHTML = `<div class="alert warning">
        <i class="ti ti-alert-triangle"></i>
        Warning: You have used ${Math.round(total / budget * 100)}% of your monthly budget.
      </div>`;
    } else {
      alertArea.innerHTML = '';
    }

    // 4. Progress bar
    if (budget > 0) {
      document.getElementById('budget-bar-wrap').style.display = 'block';
      const pct = Math.min(100, Math.round(total / budget * 100));
      document.getElementById('bar-spent').textContent = total.toLocaleString('en-IN');
      document.getElementById('bar-pct').textContent   = pct + '%';
      const bar = document.getElementById('budget-bar');
      bar.style.width      = pct + '%';
      bar.style.background = pct >= 100 ? '#E24B4A' : pct >= 80 ? '#EF9F27' : '#1D9E75';
    } else {
      document.getElementById('budget-bar-wrap').style.display = 'none';
    }

    // 5. Expense list grouped by date
    const listEl = document.getElementById('expense-list');
    if (expenses.length === 0) {
      listEl.innerHTML = `<div class="empty"><i class="ti ti-receipt-off"></i>No expenses yet.<br>Add your first one above!</div>`;
    } else {
      // Sort newest date first
      const sorted = [...expenses].sort((a, b) => b.date.localeCompare(a.date));

      // Group by date
      const grouped = {};
      sorted.forEach(e => {
        if (!grouped[e.date]) grouped[e.date] = [];
        grouped[e.date].push(e);
      });

      let html = '';
      Object.keys(grouped).forEach(date => {
        const dayTotal = grouped[date].reduce((s, e) => s + e.amount, 0);

        // Date group header
        html += `
          <div class="date-group-header">
            <span class="date-label"><i class="ti ti-calendar"></i>${formatDate(date)}</span>
            <span class="date-total">₹${dayTotal.toLocaleString('en-IN')}</span>
          </div>`;

        // Each expense in this date group
        grouped[date].forEach(e => {
          if (editingId === e.id) {
            // ── Inline edit form ──
            const catOptions = CATEGORIES.map(c =>
              `<option value="${c}" ${c === e.cat ? 'selected' : ''}>${c.charAt(0).toUpperCase() + c.slice(1)}</option>`
            ).join('');

            html += `
              <div class="edit-form">
                <div class="edit-grid">
                  <div class="field">
                    <label>Description</label>
                    <input type="text" id="edit-name-${e.id}" value="${e.name}"/>
                  </div>
                  <div class="field">
                    <label>Amount (₹)</label>
                    <input type="number" id="edit-amount-${e.id}" value="${e.amount}"/>
                  </div>
                  <div class="field">
                    <label>Category</label>
                    <select id="edit-cat-${e.id}">${catOptions}</select>
                  </div>
                  <div class="field">
                    <label>Date</label>
                    <input type="date" id="edit-date-${e.id}" value="${e.date}"/>
                  </div>
                </div>
                <div class="edit-actions">
                  <button class="btn btn-danger" onclick="cancelEdit()">
                    <i class="ti ti-x"></i> Cancel
                  </button>
                  <button class="btn btn-save" onclick="saveEdit(${e.id})">
                    <i class="ti ti-check"></i> Save
                  </button>
                </div>
              </div>`;
          } else {
            // ── Normal expense row ──
            html += `
              <div class="expense-item">
                <span class="badge badge-${e.cat}">${e.cat}</span>
                <span class="expense-name">${e.name}</span>
                <span class="expense-amount">₹${e.amount.toLocaleString('en-IN')}</span>
                <button class="icon-btn edit" onclick="startEdit(${e.id})" title="Edit">
                  <i class="ti ti-edit"></i>
                </button>
                <button class="icon-btn del" onclick="deleteExpense(${e.id})" title="Delete">
                  <i class="ti ti-trash"></i>
                </button>
              </div>`;
          }
        });
      });

      listEl.innerHTML = html;
    }

    // 6. Category breakdown bars
    const breakdown = document.getElementById('cat-breakdown');
    const catTotals = {};
    CATEGORIES.forEach(c => catTotals[c] = 0);
    expenses.forEach(e => catTotals[e.cat] += e.amount);

    const grandTotal  = expenses.reduce((s, e) => s + e.amount, 0) || 1;
    const maxCatTotal = Math.max(...Object.values(catTotals), 1);
    const activeCats  = CATEGORIES.filter(c => catTotals[c] > 0);

    if (activeCats.length === 0) {
      breakdown.innerHTML = `<div class="empty"><i class="ti ti-chart-pie"></i>No data yet.</div>`;
    } else {
      breakdown.innerHTML = activeCats.map(c => `
        <div class="cat-row">
          <div class="cat-dot" style="background:${CAT_COLORS[c]};"></div>
          <span class="cat-name">${c.charAt(0).toUpperCase() + c.slice(1)}</span>
          <div class="cat-bar-bg">
            <div class="cat-bar-fill" style="width:${Math.round(catTotals[c] / maxCatTotal * 100)}%; background:${CAT_COLORS[c]};"></div>
          </div>
          <span class="cat-pct">${Math.round(catTotals[c] / grandTotal * 100)}%</span>
          <span class="cat-amt">₹${catTotals[c].toLocaleString('en-IN')}</span>
        </div>
      `).join('');
    }
  }
</script>
</body>
</html>